#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
A2A_ROOT="$PROJECT_ROOT/a2a/team-infratructur/A2A-SIN-Google-Apps"
DIST_ENTRY="$A2A_ROOT/dist/src/cli.js"

needs_install=0
if [ ! -d "$A2A_ROOT/node_modules" ]; then
    needs_install=1
elif [ -f "$A2A_ROOT/package-lock.json" ] && [ ! -f "$A2A_ROOT/node_modules/.package-lock.json" ]; then
    needs_install=1
fi

if [ "$needs_install" -eq 1 ]; then
    npm --prefix "$A2A_ROOT" install >/dev/null
fi

needs_build=0
if [ ! -f "$DIST_ENTRY" ]; then
    needs_build=1
elif find "$A2A_ROOT/src" "$A2A_ROOT/.well-known" "$A2A_ROOT/skills" -type f \( -name '*.ts' -o -name '*.json' -o -name '*.md' \) -newer "$DIST_ENTRY" | grep -q .; then
    needs_build=1
fi

if [ "$needs_build" -eq 1 ]; then
    npm --prefix "$A2A_ROOT" run build >/dev/null
fi

exec node "$DIST_ENTRY" "$@"
