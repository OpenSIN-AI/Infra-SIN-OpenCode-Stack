#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

CORE_ROOT="${OPENCODE_CORE_DIR:-}"
if [ -z "${CORE_ROOT}" ] && [ -d "${PROJECT_ROOT}/../opencode-core" ]; then
  CORE_ROOT="${PROJECT_ROOT}/../opencode-core"
fi

if [ -z "${CORE_ROOT}" ]; then
  echo "Error: OPENCODE_CORE_DIR not set and '../opencode-core' not found." >&2
  exit 1
fi

if [ ! -d "${CORE_ROOT}/packages/opencode" ]; then
  echo "Error: expected OpenCode core at '${CORE_ROOT}/packages/opencode'." >&2
  exit 1
fi

if [ ! -d "${CORE_ROOT}/node_modules" ]; then
  (cd "${CORE_ROOT}" && bun install)
fi

exec bun run --cwd "${CORE_ROOT}/packages/opencode" --conditions=browser ./src/index.ts "$@"
