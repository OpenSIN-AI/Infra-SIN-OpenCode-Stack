#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
AGENT_ROOT="$PROJECT_ROOT/a2a/team-infratructur/A2A-SIN-Authenticator"
DIST_ENTRY="$AGENT_ROOT/dist/src/cli.js"

needs_build=0
if [ ! -f "$DIST_ENTRY" ]; then
    needs_build=1
elif find "$AGENT_ROOT/src" "$AGENT_ROOT/vendor" -type f \( -name '*.ts' -o -name '*.json' \) -newer "$DIST_ENTRY" | grep -q .; then
    needs_build=1
fi

if [ "$needs_build" -eq 1 ]; then
    npm --prefix "$AGENT_ROOT" run build >/dev/null
fi

exec node "$DIST_ENTRY" "$@"
