// ╔══════════════════════════════════════════════════════════════════╗
// ║      MY-SIN-TEAM-CODE.json — TEAM CODING AGENTEN + MODELLE      ║
// ╠══════════════════════════════════════════════════════════════════╣
// ║  TEAM: Team Coding                                               ║
// ║  MANAGER: A2A-SIN-Zeus                                           ║
// ║  ZWECK: Code schreiben, refactoren, testen, deployen             ║
// ║                                                                  ║
// ║  WAS IST DAS?                                                    ║
// ║  Konfiguration ALLER Agenten im Team Coding.                     ║
// ║  Jeder Agent hat sein eigenes optimales Modell.                  ║
// ╚══════════════════════════════════════════════════════════════════╝
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Team-Info
  "team": {
    "name": "Team Coding",
    "manager": "A2A-SIN-Zeus",
    "description": "Elite-Coder-Flotte fuer Implementation, Testing, Deployment"
  },

  // ═══════════════════════════════════════════════════════════
  // TEAM AGENTEN — Spezifische Modelle pro Team-Mitglied
  // ═══════════════════════════════════════════════════════════
  "agents": {

    // SIN-ZEUS — Supreme Fleet Commander
    // Plant lokal, erstellt GitHub Issues, dispatcht an Cloud-Executors
    "sin-zeus": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ],
      "role": "fleet-commander",
      "description": "Supreme fleet commander — plant, dispatcht, ueberwacht",
      "reasoningEffort": "xhigh"
    },

    // SIMONE MCP — Der ultimative Code-Worker
    // LSP-powered semantic code operations fuer 40+ Sprachen
    "simone-mcp": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ],
      "role": "code-worker",
      "description": "LSP-powered semantic code operations (40+ languages)"
    },

    // FRONTEND — UI/UX Specialist
    // React, Next.js, CSS, Design-Systems
    "frontend": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ],
      "role": "frontend-specialist",
      "description": "UI/UX, React, Next.js, Design-Systems, CSS"
    },

    // BACKEND — API & Services Specialist
    // FastAPI, Node.js, Databases, Infrastructure
    "backend": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ],
      "role": "backend-specialist",
      "description": "APIs, Services, Databases, Infrastructure"
    },

    // FULLSTACK — Generalist
    // Can handle both frontend and backend tasks
    "fullstack": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ],
      "role": "fullstack-generalist",
      "description": "Full-Stack — kann Frontend UND Backend"
    }
  },

  // ═══════════════════════════════════════════════════════════
  // TEAM KATEGORIEN — Modell-Auswahl nach Task-Typ
  // ═══════════════════════════════════════════════════════════
  "categories": {

    // Architecture-Design — Schwere Architektur-Entscheidungen
    "architecture": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ],
      "reasoningEffort": "xhigh"
    },

    // Implementation — Code schreiben
    "implementation": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ]
    },

    // Code-Review — Qualitaetskontrolle
    "review": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ]
    },

    // Testing — Test schreiben und ausfuehren
    "testing": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ]
    },

    // Refactoring — Code umstrukturieren
    "refactoring": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ]
    }
  }
}
