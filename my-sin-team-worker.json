// ╔══════════════════════════════════════════════════════════════════╗
// ║   MY-SIN-TEAM-WORKER.json — TEAM WORKER AGENTEN + MODELLE       ║
// ╠══════════════════════════════════════════════════════════════════╣
// ║  TEAM: Team Worker                                               ║
// ║  MANAGER: A2A-SIN-Team-Worker                                    ║
// ║  ZWECK: Surveys, Freelancing, Monetarisierung, Autonomous Work   ║
// ╚══════════════════════════════════════════════════════════════════╝
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Team-Info
  "team": {
    "name": "Team Worker",
    "manager": "A2A-SIN-Team-Worker",
    "description": "Autonome Worker fuer Surveys, Freelancing, Monetarisierung"
  },

  // ═══════════════════════════════════════════════════════════
  // TEAM AGENTEN — Spezifische Modelle pro Team-Mitglied
  // ═══════════════════════════════════════════════════════════
  "agents": {

    // PROLIFIC WORKER — Survey Automation
    // Autonome Survey-Teilnahme auf Prolific
    "prolific": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ],
      "role": "survey-worker",
      "description": "Autonome Survey-Teilnahme auf Prolific"
    },

    // FREELANCER WORKER — Freelancing Automation
    // Bewerbungen auf Freelancer-Plattformen
    "freelancer": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ],
      "role": "freelancer",
      "description": "Freelancing-Automation — Bewerbungen, Kommunikation"
    },

    // SURVEY WORKER — Allgemeine Survey Automation
    // Multi-Platform Survey Worker
    "survey": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ],
      "role": "survey-generalist",
      "description": "Allgemeine Survey Automation — Multi-Platform"
    }
  },

  // ═══════════════════════════════════════════════════════════
  // TEAM KATEGORIEN — Modell-Auswahl nach Task-Typ
  // ═══════════════════════════════════════════════════════════
  "categories": {

    // Survey Discovery — Surveys finden
    "discovery": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ]
    },

    // Survey Completion — Surveys ausfuellen
    "completion": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ]
    },

    // Communication — Emails, Nachrichten schreiben
    "communication": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "qwen/coder-model",
        "modal/glm-5.1-fp8",
        "nvidia-nim/qwen-3.5-397b"
      ]
    }
  }
}
