# OpenCode Stack Environment Variables
# Copy to .env and fill in your real values

# NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_api_key_here

# Google Gemini API (direct, not via Antigravity)
GOOGLE_API_KEY=your_google_api_key_here

# OpenRouter
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# OpenAI (via proxy)
OPENAI_API_KEY=your_openai_api_key_here

# Modal direct API
MODAL_API_KEY=

# Anthropic (via Antigravity — no direct key needed)
# ANTHROPIC_API_KEY=not_needed_use_antigravity

# Telegram Bot Tokens (for sin-telegrambot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# n8n
N8N_BASE_URL=http://your-n8n-host:5678
N8N_API_KEY=your_n8n_api_key

# OCI VM (for sin-sync)
OCI_VM_HOST=92.5.60.87
OCI_VM_USER=ubuntu

# Supabase (for sin-supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key

# Box.com Storage (A2A-SIN-Box-Storage) - NEW DEFAULT
BOX_STORAGE_URL=http://room-09-box-storage:3000
BOX_STORAGE_API_KEY=your_box_storage_shared_secret_min_32_chars
BOX_DEVELOPER_TOKEN=f9PURW50E47k9dwoVKkBD64QLJLnC4Nx  # TEMP DEV TOKEN - 1h validity!
BOX_PUBLIC_FOLDER_ID=376915767916
BOX_CACHE_FOLDER_ID=376701205578
